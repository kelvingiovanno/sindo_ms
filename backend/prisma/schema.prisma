generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  role      UserRole @default(VIEWER)
  fullname  String
  username  String   @unique
  password  String
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens Refresh[]
  storeAccesses StoreAccess[]
}

model Refresh {
  id        String   @id @default(uuid())
  token     String   @db.Text
  userId    String
  createdAt DateTime @default(now())
  expiresIn DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  storeAccesses StoreAccess[]
}

model StoreAccess {
  storeId String
  userId  String

  stores Store @relation(fields: [storeId], references: [id])
  users  User  @relation(fields: [userId], references: [id])

  @@id([storeId, userId])
}

model InventoryCategory {
  id          String      @id @default(uuid())
  name        String      @unique
  Inventories Inventory[]
}

model InventoryBrand {
  id          String      @id @default(uuid())
  name        String      @unique
  Inventories Inventory[]
}

model InventoryUnit {
  id          String      @id @default(uuid())
  name        String      @unique
  symbol      String      @unique
  Inventories Inventory[]
}

model InventoryModel {
  id         String      @id @default(uuid())
  name       String      @unique()
  invetories Inventory[]
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique
  email     String    @unique
  address   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Inventories Inventory[]
}

enum InventoryStatus {
  IN_STOCK
  OUT_OF_STOCK
  LOW_STOCK
  DISCONTINUED
}

model Inventory {
  id          String      @id @default(uuid())
  storeId     String
  sku         String      @unique
  name        String
  partnumber  String
  description String
  cost        Decimal
  price       Decimal
  stock       Decimal
  minStock    Decimal
  status      InventoryStatus
  categoryId  String
  brandId     String
  modelId     String
  unitId      String
  supplierId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  category   InventoryCategory    @relation(fields: [categoryId], references: [id])
  brand      InventoryBrand       @relation(fields: [brandId], references: [id])
  unit       InventoryUnit        @relation(fields: [unitId], references: [id])
  supplier   Supplier             @relation(fields: [supplierId], references: [id])
  model      InventoryModel       @relation(fields: [modelId], references: [id])
  dimensions InventoryDimension[]
}

model MeasurementUnit {
  id     String @id @default(uuid())
  name   String @unique
  symbol String @unique
}

model InventoryDimension {
  id          String    @id @default(uuid())
  InventoryId String
  measurement String
  value       Decimal
  unitId      String
  Inventory   Inventory @relation(fields: [InventoryId], references: [id])
}
